{
  "name": "cc-games",
  "version": "1.0.0",
  "description": "HTML5 casual games platform with Phaser 3 + Vue 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:cg": "vue-tsc && PLATFORM=cg vite build",
    "build:poki": "vue-tsc && PLATFORM=poki vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "phaser",
    "vue",
    "html5",
    "games",
    "casual"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "phaser": "^3.80.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.3.3"
  }
}
